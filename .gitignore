# ============================================================
#  Nearly — .gitignore
# ============================================================

# --- Variables d'environnement (JAMAIS COMMITER) -----------
.env
.env.*
!.env.example
!.env.docker.example
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.docker.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# --- Données utilisateurs locales (RGPD) -------------------
backend/dev_uploads/
backend/uploads/
*.pem
*.key
*.crt

# --- Python ------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# --- Node / Frontend ---------------------------------------
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Base de données locale --------------------------------
*.db
*.sqlite
*.sqlite3
*.dump
*.sql.gz

# --- Logs --------------------------------------------------
*.log
logs/

# --- OS / Editor -------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# --- Contexte projet (privé) -------------------------------
*CONTEXT.md
BUGS.md
test-cahier-recette
CLAUDE.md
backend/CLAUDE.md
frontend/CLAUDE.md
.claude/

# --- Assets & dossiers non versionnés ---------------------
Design Mobile App Interface/
ui-ux-pro-max-skill-main/
screen-*.png
screen-*.jpg

# --- Vidéos (héberger via interface web GitHub) -----------
*.mp4
*.mov
*.webm

# --- Alembic ----------------------------------------------
backend/alembic/versions/__pycache__/
