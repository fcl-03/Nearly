# Copier ce fichier en .env et remplir les valeurs

# Application
APP_NAME=Nearly
DEBUG=true
SECRET_KEY=change-this-secret-key-in-production

# Base de données PostgreSQL
DATABASE_URL=postgresql+asyncpg://nearly:nearly_dev@localhost:5432/nearly

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (origines autorisées, séparées par des virgules)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@nearly.app

# Stripe (paiements, premium — désactivé au MVP) — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_<your_stripe_test_key>
STRIPE_PRICE_ID=price_<your_price_id>
STRIPE_WEBHOOK_SECRET=whsec_<your_webhook_secret>

# Stockage fichiers (Hetzner Object Storage, compatible S3)
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_PRIVATE=nearly-private
S3_BUCKET_PUBLIC=nearly-public
