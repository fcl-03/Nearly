# Configuration Docker — URLs pointent vers les services du docker-compose
# Copier ce fichier en .env.docker et remplir les valeurs

# Application
APP_NAME=Nearly
DEBUG=false
SECRET_KEY=change-this-secret-key-in-production

# Base de données PostgreSQL (service "db" dans docker-compose)
DATABASE_URL=postgresql+asyncpg://nearly:nearly_dev@db:5432/nearly

# Redis (service "redis" dans docker-compose)
REDIS_URL=redis://:nearly_dev@redis:6379

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — origines autorisées
CORS_ORIGINS=["http://localhost"]

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# Stripe
STRIPE_SECRET_KEY=sk_test_<your_stripe_test_key>
STRIPE_PRICE_ID=price_<your_price_id>
STRIPE_WEBHOOK_SECRET=whsec_<your_webhook_secret>

# Stockage fichiers (Hetzner Object Storage)
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_PRIVATE=nearly-private
S3_BUCKET_PUBLIC=nearly-public
